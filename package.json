  },
  "homepage": "https://github.com/mturley/acp-web-relay#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
